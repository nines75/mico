{
  "name": "mico",
  "description": "ニコニコ動画用のコンテンツブロッカー",
  "version": "7.9.1",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.9",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "wxt --browser firefox --mv2",
    "build": "wxt build --browser firefox --mv2",
    "zip": "wxt zip --browser firefox --mv2",
    "postinstall": "wxt prepare",
    "preversion": "pnpm check",
    "compile": "tsc --noEmit",
    "lint": "eslint --max-warnings=0",
    "format": "prettier . --write --list-different",
    "format:ci": "prettier . --check",
    "test": "vitest",
    "test:ci": "vitest run",
    "check": "concurrently 'pnpm build' 'pnpm compile' 'pnpm lint' 'pnpm format:ci' 'pnpm test:ci'",
    "pw": "playwright test",
    "pw:install": "playwright install firefox"
  },
  "dependencies": {
    "@ag-grid-community/locale": "^36.0.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@webext-core/messaging": "^3.0.2",
    "@webext-core/proxy-service": "^2.0.1",
    "ag-grid-community": "^36.0.0",
    "ag-grid-react": "^36.0.0",
    "clsx": "^2.1.1",
    "decamelize": "^6.0.1",
    "deepmerge-ts": "^7.1.5",
    "delay": "^7.0.0",
    "dexie": "^4.4.4",
    "lucide-react": "^1.23.0",
    "modern-normalize": "^3.0.1",
    "p-queue": "^9.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-extras": "^1.2.0",
    "type-fest": "^5.8.0",
    "virtua": "^0.49.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.2.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.9.4",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
